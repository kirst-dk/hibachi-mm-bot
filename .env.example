# ========================================
# HIBACHI API CONFIGURATION
# ========================================
HIBACHI_API_ENDPOINT=https://api.hibachi.xyz
HIBACHI_DATA_API_ENDPOINT=https://data-api.hibachi.xyz
HIBACHI_API_KEY=your_api_key_here
HIBACHI_ACCOUNT_ID=your_account_id_here
HIBACHI_PRIVATE_KEY=0xyour_private_key_here

# Public Key (нужен для WebSocket mode, из Hibachi UI → API Keys)
HIBACHI_PUBLIC_KEY=your_public_key_here

# ========================================
# TELEGRAM BOT
# ========================================
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram user ID(s) кому разрешён доступ (через запятую).
# Узнать свой ID: написать @userinfobot в Telegram.
# Оставить пустым — доступ разрешён всем (НЕБЕЗОПАСНО!)
TELEGRAM_ALLOWED_USERS=123456789

# true — автоматически запустить main.py при старте tg_bot.py
TELEGRAM_AUTOSTART_BOT=false

# ========================================
# MODE
# ========================================
# false = REST polling (стабильнее, проще)
# true = WebSocket (быстрее, больше fills, нужен PUBLIC_KEY)
USE_WEBSOCKET=true

# ========================================
# TRADING PAIRS
# ========================================
# Одна пара:
HIBACHI_SYMBOLS=HYPE/USDT-P,BNB/USDT-P
# Несколько пар (через запятую, бюджет делится поровну):
# HIBACHI_SYMBOLS=BTC/USDT-P,ETH/USDT-P,SOL/USDT-P

# ========================================
# LEVERAGE (КРИТИЧЕСКИ ВАЖНО!)
# ========================================
# Для фьючерсов установлен 1x
# Стратегия разработана для торговли БЕЗ плеча
LEVERAGE=1

# ========================================
# RISK MANAGEMENT
# ========================================
# Размер базового ордера (% от баланса)
BASE_ORDER_PCT=3.0

# Максимальный инвентарь (% от баланса)
INV_BUDGET_PCT=50.0

# Slippage Guard: пропускаем котирование если TR > X * ATR
SLIP_GUARD_ATR=4.0

# Минимальный объем для котирования (0 = выключено)
MIN_VOL=0

# Long-only режим
# false = лонги и шорты разрешены
LONG_BIAS_ONLY=false

# ========================================
# SPREAD SETTINGS
# ========================================
# ATR период для расчета волатильности
ATR_LEN=14

# Таймфрейм для ATR
ATR_TIMEFRAME=15m

# Коэффициент ATR для half-spread
K_ATR=0.50

# Минимальный full spread в базисных пунктах
MIN_FULL_BPS=6.0

# Максимальный full spread в базисных пунктах
MAX_FULL_BPS=20.0

# ========================================
# INVENTORY MANAGEMENT
# ========================================
# Dampening factor для inventory offset (0-1)
# 0.3 = плавное управление, 1.0 = агрессивное
SKEW_DAMP=0.50

# Усиление sizing при разгрузке позиции
SIZE_AMP=2.2

# ========================================
# TREND BIAS
# ========================================
# Использовать бычий bias
USE_BULL_BIAS=false

# Сдвиг спреда вверх (в bps)
BULL_BIAS_BPS=0.0

# ========================================
# REQUOTE SETTINGS
# ========================================
# Порог перестановки ордеров (в bps)
# Отменяем ордера если mid сдвинулась больше этого значения
REQUOTE_BPS=1.5

# ========================================
# ORDER SETTINGS
# ========================================
# Post-only ордера (только maker)
POST_ONLY=true

# Time in force
TIME_IN_FORCE=GTC

# Минимальный notional для ордера
MIN_NOTIONAL=10.0

# Creation deadline (сек). Ордер отклоняется если биржа не успела разместить
# 0 = отключено
CREATION_DEADLINE=0

# ========================================
# LOGGING
# ========================================
# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Директория для логов
LOG_DIR=logs
